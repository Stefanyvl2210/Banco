{
  "openapi": "3.0.3",
  "info": {
    "title": "Bank API",
    "version": "1.0.0",
    "description": "Basic banking API with Sanctum authentication, accounts, and money operations."
  },
  "servers": [
    {
      "url": "/api"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/register": {
      "post": {
        "summary": "Register a user and create the first account",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "User created"
          },
          "422": {
            "description": "Invalid data"
          }
        }
      }
    },
    "/login": {
      "post": {
        "summary": "Log in",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login successful"
          },
          "401": {
            "description": "Invalid credentials"
          }
        }
      }
    },
    "/me": {
      "get": {
        "summary": "Get the authenticated user",
        "responses": {
          "200": {
            "description": "Authenticated user"
          },
          "401": {
            "description": "Unauthenticated"
          }
        }
      },
      "patch": {
        "summary": "Update the authenticated user's basic profile",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateProfileRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Profile updated"
          },
          "422": {
            "description": "Invalid data"
          }
        }
      }
    },
    "/logout": {
      "post": {
        "summary": "Log out from the current session",
        "responses": {
          "200": {
            "description": "Session closed"
          }
        }
      }
    },
    "/users": {
      "get": {
        "summary": "List users",
        "description": "Admin-only endpoint.",
        "responses": {
          "200": {
            "description": "User list"
          },
          "403": {
            "description": "Admin access is required"
          }
        }
      }
    },
    "/user/{id}": {
      "delete": {
        "summary": "Delete a user",
        "description": "Admin-only endpoint. Admin users and the current admin cannot be deleted through this endpoint.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "User deleted"
          },
          "403": {
            "description": "Admin access is required"
          },
          "404": {
            "description": "User not found"
          },
          "422": {
            "description": "User cannot be deleted"
          }
        }
      }
    },
    "/accounts": {
      "get": {
        "summary": "List owned accounts",
        "responses": {
          "200": {
            "description": "Authenticated user's accounts"
          }
        }
      }
    },
    "/account": {
      "post": {
        "summary": "Create an additional account",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateAccountRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Account created"
          },
          "422": {
            "description": "Invalid data"
          }
        }
      }
    },
    "/transactions": {
      "get": {
        "summary": "List owned transactions",
        "responses": {
          "200": {
            "description": "Paginated transactions"
          }
        }
      }
    },
    "/deposit": {
      "put": {
        "summary": "Deposit into an owned account",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AccountOperationRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Deposit completed"
          },
          "422": {
            "description": "Invalid account or amount"
          }
        }
      }
    },
    "/withdrawal": {
      "put": {
        "summary": "Withdraw from an owned account",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AccountOperationRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Withdrawal completed"
          },
          "422": {
            "description": "Invalid account or insufficient balance"
          }
        }
      }
    },
    "/transaction": {
      "post": {
        "summary": "Transfer between accounts",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TransferRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Transfer completed"
          },
          "422": {
            "description": "Invalid account or insufficient balance"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "Sanctum"
      }
    },
    "schemas": {
      "RegisterRequest": {
        "type": "object",
        "required": ["first_name", "last_name", "email", "password", "account_type"],
        "properties": {
          "first_name": { "type": "string", "example": "Ana" },
          "last_name": { "type": "string", "example": "Perez" },
          "phone": { "type": "string", "example": "04141234567" },
          "email": { "type": "string", "format": "email", "example": "ana@example.com" },
          "password": { "type": "string", "format": "password", "example": "password123" },
          "account_type": { "type": "string", "enum": ["checking", "savings"], "example": "savings" }
        }
      },
      "LoginRequest": {
        "type": "object",
        "required": ["email", "password"],
        "properties": {
          "email": { "type": "string", "format": "email", "example": "ana@example.com" },
          "password": { "type": "string", "format": "password", "example": "password123" }
        }
      },
      "UpdateProfileRequest": {
        "type": "object",
        "properties": {
          "first_name": { "type": "string", "example": "Andrea" },
          "last_name": { "type": "string", "example": "Lopez" },
          "phone": { "type": "string", "example": "04147654321" }
        }
      },
      "CreateAccountRequest": {
        "type": "object",
        "required": ["account_type"],
        "properties": {
          "account_type": { "type": "string", "enum": ["checking", "savings"], "example": "checking" }
        }
      },
      "AccountOperationRequest": {
        "type": "object",
        "required": ["account_number", "amount"],
        "properties": {
          "account_number": { "type": "string", "example": "501878200000001" },
          "account_type": { "type": "string", "enum": ["checking", "savings"], "example": "savings" },
          "amount": { "type": "string", "pattern": "^\\d+(\\.\\d{1,2})?$", "example": "25.50" }
        }
      },
      "TransferRequest": {
        "type": "object",
        "required": ["source_account_number", "destination_account_number", "amount"],
        "properties": {
          "source_account_number": { "type": "string", "example": "501878200000001" },
          "destination_account_number": { "type": "string", "example": "501878200000002" },
          "amount": { "type": "string", "pattern": "^\\d+(\\.\\d{1,2})?$", "example": "10.00" },
          "transaction_type": { "type": "string", "enum": ["transfer"], "example": "transfer" }
        }
      }
    }
  }
}
